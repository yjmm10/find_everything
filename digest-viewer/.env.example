# GitHub Pages 子路径（CI 已设 VITE_BASE=/find_everything/）
# VITE_BASE=/

# 访客统计（任选其一或组合；留空则不加载）
# Google Analytics 4 衡量 ID（G-XXXXXXXXXX）
# VITE_GA_MEASUREMENT_ID=

# Umami（自托管或 cloud.umami.is）
# VITE_UMAMI_WEBSITE_ID=
# VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# GoatCounter（如 https://yourname.goatcounter.com）
# VITE_GOATCOUNTER_ENDPOINT=https://yourname.goatcounter.com/count
