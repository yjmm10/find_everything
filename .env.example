# 复制为 .env 后填入真实值（.env 勿提交仓库）

# --- AI 周报生成（必填其一：OpenAI 或兼容网关）---
OPENAI_API_KEY=
# 官方默认 https://api.openai.com/v1 ；ModelScope 等兼容网关需以 /v1 结尾
OPENAI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# AI_MAX_TOKENS=4000

# --- 学术检索（可选；未配置时使用公开限额）---
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
# OPENALEX_MAILTO=you@example.com

# --- 抓取覆盖（可选）---
# KEYWORDS=llm, agent
# DIGEST_CONFIG=digest_config.yaml
# DIGEST_DATE_START=2026-05-01
# DIGEST_DATE_END=2026-05-07
# DIGEST_DATE_PRESET=week

# --- GitHub API（github_repository_search / 周榜 enrich 建议配置）---
# GITHUB_TOKEN=

# --- 通知（可选）---
# SMTP_SERVER=
# EMAIL_USER=
# EMAIL_PASS=
# RECIPIENT_EMAIL=
# WEBHOOK_URL=
