# 复制为 .env 后填入真实值（.env 勿提交仓库）
#
# 业务配置（关键词、时间窗、各信息源、AI 模型等）请改 digest_config.yaml。
# 此处仅放密钥、CI 开关与临时覆盖项。

# --- AI 网关（必填）---
# 魔搭 ModelScope（推荐，模型见 digest_config.yaml，如 deepseek-ai/DeepSeek-V3.2）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api-inference.modelscope.cn/v1
# 官方 OpenAI：OPENAI_API_BASE=https://api.openai.com/v1
# 智谱 Coding Plan：OPENAI_API_BASE=https://open.bigmodel.cn/api/coding/paas/v4
# 可选后备：未在 digest_config.yaml 配置 ai.model 时使用
# AI_MODEL=gpt-4o-mini

# --- AI 备用网关（主模型失败时回退，模型见 digest_config.yaml ai.fallback_models）---
# MINIMAX_API_KEY=
# MINIMAX_API_BASE=https://api.minimaxi.com/v1
# 可选覆盖备用模型列表（逗号分隔，默认 MiniMax-M2.7,MiniMax-M2.5）
# AI_FALLBACK_MODELS=MiniMax-M2.7,MiniMax-M2.5

# --- 学术检索 API Key（可选）---
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
# OPENALEX_MAILTO=you@example.com

# --- CI（GitHub Actions 将 data/ 发布到 gh-pages，本地勿设）---
# DIGEST_NO_GIT=1
# 可选：同时导出 docs/*.md 副本（默认仅写 data/runs/*.json）
# DIGEST_EXPORT_MD=1

# --- 临时覆盖（一般不必设，改 digest_config.yaml 即可）---
# KEYWORDS=llm, agent
# DIGEST_CONFIG=digest_config.yaml
# DIGEST_DATE_START=2026-05-01
# DIGEST_DATE_END=2026-05-07
# DIGEST_DATE_PRESET=week

# --- GitHub API（github_repository_search / 周榜 enrich 建议配置）---
# GITHUB_TOKEN=

# --- 通知（可选）---
# SMTP_SERVER=
# EMAIL_USER=
# EMAIL_PASS=
# RECIPIENT_EMAIL=
# WEBHOOK_URL=
